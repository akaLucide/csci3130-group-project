<?xml version="1.0" encoding="utf-8"?>

<!-- Main layout for Forgot Password screen -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- Page title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Reset Password"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginBottom="8dp" />

    <!-- Short instruction under title -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Use the email you signed up with to receive a reset link."
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <!-- Email input field -->
    <EditText
        android:id="@+id/emailInput"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:autofillHints="emailAddress"
        android:layout_marginBottom="16dp" />

    <!-- Button to trigger password reset -->
    <Button
        android:id="@+id/resetPasswordButton"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="Send Reset Link"
        android:layout_marginBottom="12dp" />

    <!-- Displays validation or success messages -->
    <TextView
        android:id="@+id/statusMessage"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp" />

</LinearLayout>